{
  "env": {
    "ANTHROPIC_BASE_URL": "https://api.minimax.io/anthropic",
    "ANTHROPIC_AUTH_TOKEN": "${ANTHROPIC_AUTH_TOKEN}",
    "ANTHROPIC_MODEL": "MiniMax-M2.7",
    "ANTHROPIC_SMALL_FAST_MODEL": "MiniMax-M2.7",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "MiniMax-M2.7",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "MiniMax-M2.7",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "MiniMax-M2.7",
    "CLAUDE_CODE_SUBAGENT_MODEL": "MiniMax-M2.7",
    "API_TIMEOUT_MS": "3000000",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(**)",
      "Edit(**)"
    ],
    "deny": [
      "Read(*aurelia.env*)",
      "Read(*terraform.tfvars*)",
      "Read(*id_rsa*)",
      "Bash(apt upgrade*)",
      "Bash(apt dist-upgrade*)",
      "Bash(do-release-upgrade*)",
      "Bash(coolify update*)",
      "Bash(zpool upgrade*)",
      "Bash(zfs destroy*)",
      "Bash(terraform destroy*)",
      "Bash(curl *coolify.io/install*)",
      "Bash(docker pull coollabsio/coolify:latest*)",
      "Bash(chmod 777*)",
      "Bash(shred*)",
      "Bash(.claude/hooks/**)",
      "Bash(curl *untrusted*)",
      "Read(**/CLAUDE.md)",
      "Read(**/.mcp.json)",
      "Edit(**/.mcp.json)"
    ],
    "defaultMode": "ask"
  },
  "model": "haiku",
  "enabledPlugins": {
    "commit-commands@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "hookify@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "explanatory-output-style@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true
  },
  "skipDangerousModePermissionPrompt": true,
  "mcpServers": {
    "filesystem": {
      "command": "node",
      "args": [
        "/home/will/.npm-global/lib/node_modules/@j0hanz/filesystem-mcp/dist/index.js"
      ],
      "env": {}
    },
    "git": {
      "command": "node",
      "args": [
        "/home/will/.npm-global/lib/node_modules/@cyanheads/git-mcp-server/dist/index.js"
      ],
      "env": {}
    },
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ],
      "env": {}
    },
    "memory-keeper": {
      "command": "npx",
      "args": [
        "mcp-memory-keeper"
      ],
      "env": {
        "DATA_DIR": "/home/will/.mcp-data/memory-keeper",
        "TOOL_PROFILE": "standard"
      }
    },
    "github": {
      "type": "stdio",
      "command": "node",
      "args": [
        "/home/will/.npm-global/lib/node_modules/@modelcontextprotocol/server-github/dist/index.js"
      ],
      "env": {}
    },
    "playwright": {
      "command": "/home/will/.npm-global/bin/chrome-devtools-mcp",
      "args": [],
      "env": {}
    },
    "tavily": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-tavily"
      ],
      "env": {
        "TAVILY_API_KEY": "${TAVILY_API_KEY}"
      }
    }
  }
}
